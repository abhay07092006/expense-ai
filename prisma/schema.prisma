generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  clerkId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())

  expenses Expense[]
}

model Expense {
  id         String   @id @default(cuid())

  title      String
  amount     Float
  category   String
  payment    String
  date       DateTime
  notes      String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}